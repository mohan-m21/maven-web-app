<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TECH EXPERT SOLUTION INDIA</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #e4e9fd 100%);
            color: #333;
            line-height: 1.6;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .container {
            background: white;
            border-radius: 16px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
            padding: 50px 40px;
            max-width: 800px;
            width: 100%;
            text-align: center;
            border: 1px solid #e0e7ff;
        }

        h1 {
            color: #006400;           /* Dark green */
            font-size: 2.4rem;
            margin-bottom: 1.5rem;
            font-weight: 700;
            line-height: 1.3;
        }

        h2 {
            color: #2c3e50;
            font-size: 1.35rem;
            margin: 1.2rem 0 0.8rem;
            font-weight: 600;
        }

        .highlight-phone {
            color: #d32f2f;           /* Red for phone numbers */
            font-weight: 700;
            font-size: 1.45rem;
            margin: 0.8rem 0;
            letter-spacing: 0.5px;
        }

        .company-link {
            display: inline-block;
            margin: 2rem 0 1.5rem;
            padding: 14px 32px;
            background: #006400;
            color: white;
            text-decoration: none;
            font-size: 1.2rem;
            font-weight: 600;
            border-radius: 50px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(0, 100, 0, 0.25);
        }

        .company-link:hover {
            background: #004d00;
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(0, 100, 0, 0.35);
        }

        .tagline {
            color: #555;
            font-size: 1.15rem;
            margin-bottom: 2rem;
            max-width: 680px;
            margin-left: auto;
            margin-right: auto;
        }

        @media (max-width: 600px) {
            .container {
                padding: 35px 25px;
            }
            h1 {
                font-size: 2rem;
            }
            .company-link {
                font-size: 1.1rem;
                padding: 12px 28px;
            }
        }
    </style>
</head>
<body>

    <div class="container">
        <h1>Welcome to TECH EXPERT SOLUTION INDIA</h1>
        
        <p class="tagline">
            Your career partner! One of India's best Training destinations for Software, Networking, and Cloud Computing courses with 18 years of Industrial experience.
        </p>

        <a href="https://scopeindia.org" class="company-link" target="_blank">
            Click Here to see more about our company →
        </a>

        <h2>Contact Us / WhatsApp</h2>
        <div class="highlight-phone">
            +91 97459 36073
        </div>
        <div class="highlight-phone">
            +91 75929 39481
        </div>
        <div class="highlight-phone">
            +91 80755 36185
        </div>
    </div>

</body>
</html>
